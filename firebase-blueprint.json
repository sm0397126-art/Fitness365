{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "member"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Program": {
      "title": "Gym Program",
      "description": "Details of a gym program",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "description", "image", "category"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "Image for the gallery",
      "type": "object",
      "properties": {
        "src": { "type": "string", "format": "uri" },
        "alt": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["src", "alt", "category"]
    },
    "Inquiry": {
      "title": "Contact Inquiry",
      "description": "Inquiry from the contact form",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "goal": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/programs/{programId}": {
      "schema": "Program",
      "description": "Gym programs"
    },
    "/gallery/{imageId}": {
      "schema": "GalleryImage",
      "description": "Gallery images"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Contact form submissions"
    }
  }
}
